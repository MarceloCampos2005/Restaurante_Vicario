<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <title>HTML Request Parameters</title>
</head>
<body>
<h3>Choose a student:</h3>
<form method="get">
    <input type="checkbox" name="student" value="Ricardo">Student 1<br>
    <input type="checkbox" name="student" value="Sofia">Student 2<br>
    <input type="checkbox" name="student" value="Bruno">Student 3<br>
    <input type="submit" value="Query">
</form>

<%
    String[] stds = request.getParameterValues("student");
    if (stds != null) {
%>
<h3>You have selected the following student(s):</h3>
<ul>
    <%
        for (int i = 0; i < stds.length; i++) {
    %>
    <li><%= stds[i] %></li>
    <%
        }
    %>
</ul>
<%
    }
%>

<a href="<%= request.getRequestURI() %>">Go back</a>
</body>
</html>


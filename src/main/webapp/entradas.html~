<form action="adicionar.jsp" class="adicionar" method="post">
    <div class="container">
        <h1 class="titulo">Entradas</h1>
        <input id="pratoSelecionado" name="pratoSelecionado" type="hidden">

        <div class="direita">
            <img alt="tabuaenchidos" src="images/tabuaenchidos.png">
            <div class="card-content">
                <h2>Tábua de Enchidos Artesanais</h2>
                <p>Descubra a nossa seleção de enchidos artesanais,<br> acompanhada de pão crocante e compota
                    caseira,<br> perfeita para partilhar e saborear momentos especiais.</p>
                <p class="price">Preço: 14,00€</p>
                <input class="botao" onclick="selecionarPrato('tabua de enchidos artesanais')" type="submit" value="Adicionar ao pedido">

                <label class="botao" for="popup4">Adicionar ao
                    pedido</label>
            </div>
        </div>

        <div class="esquerda">
            <img alt="canape" src="images/canape.png">
            <div class="card-content">
                <h2>Canapés Gourmet</h2>
                <p class="desc">Deliciosas combinações de sabores em canapés<br> artesanais, perfeitos para começar a
                    sua experiência<br> gastronómica com elegância e requinte.</p>
                <p class="price">Preço: 12,00€ (10-12 unidades)</p>
                <input class="botao" onclick="selecionarPrato('canapes gourmet')" type="submit" value="Adicionar ao pedido">
                <label class="botao" for="popup4">Adicionar ao
                    pedido</label>
            </div>
        </div>

        <div class="direita">
            <img alt="batatarecheada" src="images/batatarecheada.png">
            <div class="card-content">
                <h2>Batatas Recheadas Gourmet</h2>
                <p>Batatas assadas com creme, queijo cheddar, bacon<br> crocante e ervas frescas, combinando sabores
                    e<br> texturas irresistíveis.</p>
                <p class="price">Preço: 10,00€ (3 unidades)</p>
                <input class="botao" onclick="selecionarPrato('batatas recheadas gourmet')" type="submit" value="Adicionar ao pedido">

                <label class="botao" for="popup4">Adicionar ao
                    pedido</label>
            </div>
        </div>
        <input type="hidden" name="origem" value="entradas.html">

        <div class="esquerda">
            <img alt="croquetes" src="images/croquetes.png">
            <div class="card-content">
                <h2>Croquetes Recheados</h2>
                <p class="desc">Croquetes dourados e crocantes, com um recheio<br> cremoso e saboroso, perfeitos para
                    uma experiência<br> de sabor irresistível.</p>
                <p class="price">Preço: 9,00€ (6 unidades)</p>
                <input class="botao" onclick="selecionarPrato('croquetes recheados')" type="submit" value="Adicionar ao pedido">
                <label class="botao" for="popup4">Adicionar ao pedido</label>
            </div>
        </div>
    </div>
    <!-- Popup -->
    <input class="popup-checkbox" id="popup4" type="checkbox">
    <div class="popup-overlay">
        <div class="popup-content">
            <p class="negrito">Sucesso</p>
            <p class="desc">O artigo selecionado foi adicionado ao<br>pedido!</p>
            <label class="close-btn" for="popup4">Fechar</label>
        </div>
    </div>
</form>
